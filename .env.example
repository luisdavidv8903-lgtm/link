# Optional: only needed if the Worker is deployed to a *.workers.dev URL
# instead of routed on the same domain. Leave unset to use the default
# same-origin "/api/chat" endpoint.
VITE_CHAT_API_URL=

# Required for the Government Readiness Assessment lead capture.
# Use the public anon key from Supabase Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Worker secret, NOT exposed to the frontend):
#   wrangler secret put ANTHROPIC_API_KEY

# Server-side only for /api/admin-leads:
# ADMIN_TOKEN protects /admin data access.
# SUPABASE_SERVICE_ROLE_KEY must never be exposed to the browser.
ADMIN_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
